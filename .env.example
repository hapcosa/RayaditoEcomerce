# Piedras Rayadito — variables de entorno.
# Copia este archivo a .env y ajusta los valores. NUNCA subas .env al repositorio.

# --- Núcleo ---
DEBUG=true
SECRET_KEY=change-me-dev-only-generate-a-real-one-in-prod

# --- Base de datos (los valores por defecto calzan con docker-compose.yml) ---
DB_NAME=piedrasrayadito
DB_USER=rayadito
DB_PASSWORD=rayadito
DB_HOST=127.0.0.1
DB_PORT=15432

# --- Hosts / CORS / CSRF (listas separadas por coma) ---
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- OAuth Google / Facebook (opcional en desarrollo) ---
GOOGLE_CLIENT_KEY=
GOOGLE_CLIENT_SECRET=

# --- Email (en desarrollo usa la consola; en producción define SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Piedras Rayadito <no-reply@piedrasrayadito.cl>

# --- MercadoPago (Fase 2) ---
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_WEBHOOK_SECRET=
# MERCADOPAGO_NOTIFICATION_URL=https://tu-dominio.cl/api/payment/webhook
# FRONTEND_BASE_URL=http://127.0.0.1:5173

# --- Producción: forzar HTTPS/HSTS (dejar comentado en dev) ---
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000

# --- pgAdmin (docker-compose) ---
PGADMIN_EMAIL=admin@rayadito.local
PGADMIN_PASSWORD=admin
